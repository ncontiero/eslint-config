{
  "name": "@ncontiero/eslint-config",
  "type": "module",
  "version": "8.3.3",
  "packageManager": "pnpm@11.10.0",
  "description": "Nicolas's ESLint config.",
  "author": {
    "name": "Nicolas Contiero",
    "url": "https://github.com/ncontiero"
  },
  "license": "MIT",
  "homepage": "https://github.com/ncontiero/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ncontiero/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/ncontiero/eslint-config/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm typegen && tsdown",
    "dev": "pnpm inspector",
    "build:inspector": "pnpm build && pnpm inspector build --outDir .eslint-config-inspector",
    "typegen": "tsx scripts/typegen.ts",
    "inspector": "eslint-config-inspector --config eslint-inspector.config.ts",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@tanstack/eslint-plugin-query": ">=5.50.0",
    "eslint": ">=9.20.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/eslint-plugin-query": {
      "optional": true
    }
  },
  "dependencies": {
    "@e18e/eslint-plugin": "^0.5.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^5.13.0",
    "@eslint/markdown": "^8.0.3",
    "@html-eslint/eslint-plugin": "^0.63.0",
    "@html-eslint/parser": "^0.63.0",
    "@next/eslint-plugin-next": "^16.2.10",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-antfu": "^3.2.3",
    "eslint-plugin-better-tailwindcss": "4.6.1",
    "eslint-plugin-command": "^3.5.2",
    "eslint-plugin-de-morgan": "^2.1.2",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.12",
    "eslint-plugin-jsonc": "^3.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-toml": "^1.4.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-yml": "^3.6.0",
    "globals": "^17.7.0",
    "local-pkg": "^1.2.1",
    "prettier": "^3.9.4",
    "toml-eslint-parser": "^1.0.3",
    "yaml-eslint-parser": "^2.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/config-inspector": "^3.0.4",
    "@ncontiero/changelog-github": "^2.1.4",
    "@ncontiero/prettier-config": "^1.0.0",
    "@tanstack/eslint-plugin-query": "^5.101.2",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25.9.5",
    "eslint": "^10.6.0",
    "eslint-typegen": "^2.3.1",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "tinyexec": "^1.2.4",
    "tinyglobby": "^0.2.17",
    "tsdown": "^0.22.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "nano-staged": {
    "*": "pnpm lint:fix"
  },
  "prettier": "@ncontiero/prettier-config"
}
