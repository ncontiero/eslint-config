{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "noEmit": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["./fixtures/**/*.*", "./_fixtures/**/*.*"]
}
